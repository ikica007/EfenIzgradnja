rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - User ID
    //   - email: string (required) - User email
    //   - role: string (required, 'user' or 'admin') - User role
    //   - createdAt: timestamp (optional) - Creation time
    //
    // Collection: content
    // Document ID: {sectionId}
    // Fields:
    //   - title: string (required) - Section title
    //   - subtitle: string (optional) - Section subtitle
    //   - imageUrl: string (optional) - Section image URL
    //   - updatedAt: timestamp (optional) - Last update time
    //
    // Collection: notifications
    // Document ID: {notificationId}
    // Fields:
    //   - title: string (required) - Notification title
    //   - message: string (required) - Notification message
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "dobardzicilijas123@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['user', 'admin'];
    }
    
    function isValidContent(data) {
      return hasOnlyAllowedFields(['title', 'subtitle', 'imageUrl', 'updatedAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             (!('subtitle' in data) || (data.subtitle is string && data.subtitle.size() < 2000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1000));
    }

    function isValidNotification(data) {
      return hasOnlyAllowedFields(['title', 'message', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 2000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile, but only as 'user' unless they are already an admin
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && request.resource.data.role == 'user' && request.resource.data.uid == userId) ||
        isAdmin()
      );
      
      // Only admins can update roles. Users can update their own profile but not their role.
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.uid == resource.data.uid) ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    match /content/{sectionId} {
      // Anyone can read content
      allow read: if true;
      
      // Only admins can modify content
      allow create, update: if isAdmin() && isValidContent(request.resource.data);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      // Any authenticated user can read notifications
      allow read: if isAuthenticated();
      
      // Only admins can create or delete notifications
      allow create: if isAdmin() && isValidNotification(request.resource.data);
      allow update: if false; // Notifications are immutable
      allow delete: if isAdmin();
    }
  }
}
